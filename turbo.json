{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        ".astro/**",
        ".dist/**"
      ]
    },
    "publish": {
      "dependsOn": [
        "build"
      ],
      "cache": false,
      "outputs": []
    }
  }
}
